# Environment Variables for Fresh Mart Database Connection
# Copy this file to .env and update with your specific values

# SQL Server Configuration
DB_SERVER=DESKTOP-OBE55B8
DB_INSTANCE=SQLEXPRESS
DB_NAME=FreshMartDB

# Authentication (Windows Authentication - no username/password needed)
# Leave these empty for Windows Auth
DB_USERNAME=
DB_PASSWORD=

# JWT Secret for authentication tokens
JWT_SECRET=supersecretkey123

# Server Configuration
PORT=3000

# Connection Pool Settings (optional - adjust based on your needs)
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_CONNECT_TIMEOUT=30000
DB_REQUEST_TIMEOUT=30000